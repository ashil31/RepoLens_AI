# ─────────────────────────────────────────────────────────────────────────────
# RepoLens Backend – Environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# API base path (no trailing slash). Routes are mounted at BASE_PATH/v1
BASE_PATH=/api

# Frontend origin for CORS. Must be a specific origin (not *) when using cookies.
# Set to your frontend URL so refresh token cookie is sent (e.g. http://localhost:3000).
FRONTEND_ORIGIN=http://localhost:3000

# JWT secrets (use strong random values in production)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# JWT expiry (access = short-lived, refresh = long-lived for "remember me")
# Access: e.g. 15m, 1h. Refresh: e.g. 7d, 30d. Units: s, m, h, d.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ─────────────────────────────────────────────────────────────────────────────
# GitHub App Integration (Module 4)
# ─────────────────────────────────────────────────────────────────────────────
# Create a GitHub App at https://github.com/settings/apps
# Webhook URL: use your ngrok URL + /api/v1/github/webhook (see docs/GITHUB_NGROK_SETUP.md)
# Copy these to .env and fill with REAL values. Never commit .env or put real keys in this file.
# ─────────────────────────────────────────────────────────────────────────────

GITHUB_APP_ID=

# Full contents of the .pem file (from GitHub App → Private keys). Use quotes; newlines as \n or real newlines.
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"

# Same value as "Webhook secret" in GitHub App settings (use a strong random string)
GITHUB_WEBHOOK_SECRET=

# Install link: replace repolens-dev with your app slug
GITHUB_APP_INSTALL_URL=https://github.com/apps/repolens-dev/installations/new

# Where GitHub redirects after install (your frontend page)
GITHUB_APP_CALLBACK_URL=http://localhost:3000/github/callback

# AI (DigitalOcean Gradient™ – used for repo overview & architecture analysis)
# Get your model access key from the Gradient dashboard
MODEL_ACCESS_KEY=
GEMINI_API_KEY=
# Optional: clone and queue
# REPO_CLONE_DIR=/tmp/repos
# REPO_CLONE_TIMEOUT=120000
# REDIS_URL=
