# ─────────────────────────────────────────────────────────────────────────────
# RepoLens Backend – Environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# API base path (no trailing slash). Routes are mounted at BASE_PATH/v1
BASE_PATH=/api

# Frontend origin for CORS. Must be a specific origin (not *) when using cookies.
# Set to your frontend URL so refresh token cookie is sent (e.g. http://localhost:3000).
FRONTEND_ORIGIN=http://localhost:3000

# JWT secrets (use strong random values in production)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# JWT expiry (access = short-lived, refresh = long-lived for "remember me")
# Access: e.g. 15m, 1h. Refresh: e.g. 7d, 30d. Units: s, m, h, d.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
