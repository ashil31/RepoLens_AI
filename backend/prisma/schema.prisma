generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  fullName     String?
  username     String?  @unique
  profileImage String?
  isVerified   Boolean  @default(false)
  credits      Int      @default(2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens       RefreshToken[]
  otps                Otp[]
  workspaceMembers    WorkspaceMember[]
  githubInstallations GitHubInstallation[]

  @@map("users")
}

// ─────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  device    String?
  ip        String?
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// OTP
// ─────────────────────────────────────────
model Otp {
  id        String   @id @default(cuid())
  code      String
  type      OtpType  @default(EMAIL_VERIFICATION)
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ─────────────────────────────────────────
// WORKSPACE & MEMBERSHIP
// ─────────────────────────────────────────
enum WorkspaceRole {
  OWNER
  MEMBER
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             WorkspaceMember[]
  repositories        Repository[]
  githubInstallations GitHubInstallation[]

  @@map("workspaces")
}

model WorkspaceMember {
  id       String        @id @default(cuid())
  role     WorkspaceRole @default(MEMBER)
  joinedAt DateTime      @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ─────────────────────────────────────────
// GITHUB INSTALLATION (App integration)
// ─────────────────────────────────────────
model GitHubInstallation {
  id                   String    @id @default(cuid())
  githubInstallationId Int
  githubAccountLogin   String
  githubAccountId      Int
  userId               String
  workspaceId          String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@map("github_installations")
}

// ─────────────────────────────────────────
// REPOSITORY
// ─────────────────────────────────────────
model Repository {
  id          String     @id @default(cuid())
  owner       String
  name        String
  description String?
  repoUrl     String? // Added this for easier cloning
  language    String?
  stars       Int?
  isPrivate   Boolean    @default(false)
  status      RepoStatus @default(PENDING)
  analyzedAt  DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documentation String? @db.Text
  architecture  String? @db.Text
  totalFiles    Int?
  mainLanguage  String?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  files           RepositoryFile[]
  analysisJobs    AnalysisJob[]
  dependencies    RepositoryDependency[]

  @@unique([workspaceId, owner, name])
  @@map("repositories")
}

enum RepoStatus {
  PENDING
  CLONING
  ANALYZING
  COMPLETED
  FAILED
}

model AnalysisJob {
  id           String    @id @default(cuid())
  repositoryId String
  status       JobStatus @default(PENDING)
  currentStep  JobStep?
  progress     Int       @default(0)
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  logs         Json? // Array of log strings
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, status])
  @@map("analysis_jobs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobStep {
  FETCHING_REPO
  DOWNLOADING_FILES
  PARSING_CODE
  BUILDING_GRAPH
  EMBEDDING
  GENERATING_AI
  DONE
}

// ─────────────────────────────────────────
// REPOSITORY FILE
// ─────────────────────────────────────────
model RepositoryFile {
  id        String   @id @default(cuid())
  path      String // Relative path in repo
  language  String?
  content   String?  @db.Text
  tokenSize Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  symbols    Json?
  chunkCount Int?

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  embeddings CodeEmbedding[]

  @@unique([repositoryId, path])
  @@map("repository_files")
}

// ─────────────────────────────────────────
// CODE EMBEDDING
// ─────────────────────────────────────────
model CodeEmbedding {
  id        String                       @id @default(cuid())
  chunk     String                       @db.Text
  embedding Unsupported("vector(1536)")? // OpenAI embedding size
  startLine Int?
  endLine   Int?
  createdAt DateTime                     @default(now())

  fileId String
  file   RepositoryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("code_embeddings")
}

// ─────────────────────────────────────────
// REPOSITORY DEPENDENCY
// ─────────────────────────────────────────
model RepositoryDependency {
  id           String     @id @default(cuid())
  sourcePath   String
  targetPath   String
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sourcePath, targetPath])
  @@map("repository_dependencies")
}
