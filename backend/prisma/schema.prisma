generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String?
  credits             Int                  @default(2)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  googleId            String?              @unique
  isVerified          Boolean              @default(false)
  fullName            String?
  profileImage        String?
  username            String?              @unique
  githubInstallations GitHubInstallation[]
  otps                Otp[]
  refreshTokens       RefreshToken[]
  workspaceMembers    WorkspaceMember[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  device    String?
  ip        String?
  revoked   Boolean  @default(false)
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Otp {
  id        String   @id @default(cuid())
  code      String
  type      OtpType  @default(EMAIL_VERIFICATION)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  githubInstallations GitHubInstallation[]
  repositories        Repository[]
  members             WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  workspaceId String
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model GitHubInstallation {
  id                   String    @id @default(cuid())
  githubInstallationId Int
  githubAccountLogin   String
  githubAccountId      Int
  userId               String
  workspaceId          String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("github_installations")
}

model Repository {
  id            String                 @id @default(cuid())
  owner         String
  name          String
  description   String?
  language      String?
  stars         Int?
  isPrivate     Boolean                @default(false)
  analyzedAt    DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  repoUrl       String?
  workspaceId   String
  status        RepoStatus             @default(PENDING)
  architecture  String?
  documentation String?
  mainLanguage  String?
  totalFiles    Int?
  analysisJobs  AnalysisJob[]
  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dependencies  RepositoryDependency[]
  files                RepositoryFile[]
  repositoryEmbedding  RepositoryEmbedding?

  @@unique([workspaceId, owner, name])
  @@map("repositories")
}

model AnalysisJob {
  id           String     @id @default(cuid())
  repositoryId String
  status       JobStatus  @default(PENDING)
  currentStep  JobStep?
  progress     Int        @default(0)
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  logs         Json?
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, status])
  @@map("analysis_jobs")
}

model RepositoryFile {
  id           String          @id @default(cuid())
  path         String
  contentHash  String?         // sha256(content) - skip re-embedding if unchanged
  language     String?
  content      String?
  tokenSize    Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  repositoryId String
  chunkCount   Int?
  symbols      Json?
  embeddings   CodeEmbedding[]
  repository   Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, path])
  @@map("repository_files")
}

model CodeEmbedding {
  id         String                 @id @default(cuid())
  chunk      String
  embedding  Unsupported("vector(384)")?
  startLine  Int?
  endLine    Int?
  createdAt  DateTime               @default(now())
  fileId     String
  symbolName String?
  language   String?
  file       RepositoryFile         @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@map("code_embeddings")
}

model RepositoryEmbedding {
  id           String                 @id @default(cuid())
  repositoryId String                 @unique
  summary      String
  embedding    Unsupported("vector(384)")
  createdAt    DateTime               @default(now())
  repository   Repository             @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@map("repository_embeddings")
}

model RepositoryDependency {
  id           String     @id @default(cuid())
  sourcePath   String
  targetPath   String
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sourcePath, targetPath])
  @@map("repository_dependencies")
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum RepoStatus {
  PENDING
  CLONING
  ANALYZING
  COMPLETED
  FAILED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobStep {
  FETCHING_REPO
  DOWNLOADING_FILES
  PARSING_CODE
  BUILDING_GRAPH
  EMBEDDING
  GENERATING_AI
  DONE
}
