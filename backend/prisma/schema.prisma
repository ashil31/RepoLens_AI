generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  isVerified   Boolean  @default(false)
  credits      Int      @default(2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repositories  Repository[]
  refreshTokens RefreshToken[]
  otps          Otp[]

  @@map("users")
}

// ─────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  device    String?
  ip        String?
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// OTP
// ─────────────────────────────────────────
model Otp {
  id        String   @id @default(cuid())
  code      String
  type      OtpType  @default(EMAIL_VERIFICATION)
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ─────────────────────────────────────────
// REPOSITORY
// ─────────────────────────────────────────
model Repository {
  id          String   @id @default(cuid())
  owner       String
  name        String
  description String?
  repoUrl     String? // Added this for easier cloning
  language    String?
  stars       Int?
  isPrivate   Boolean  @default(false)
  analyzedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  files RepositoryFile[]

  @@unique([userId, owner, name])
  @@map("repositories")
}

// ─────────────────────────────────────────
// REPOSITORY FILE
// ─────────────────────────────────────────
model RepositoryFile {
  id        String   @id @default(cuid())
  path      String // Relative path in repo
  language  String?
  content   String?  @db.Text
  tokenSize Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  embeddings CodeEmbedding[]

  @@unique([repositoryId, path])
  @@map("repository_files")
}

// ─────────────────────────────────────────
// CODE EMBEDDING
// ─────────────────────────────────────────
model CodeEmbedding {
  id        String                       @id @default(cuid())
  chunk     String                       @db.Text
  embedding Unsupported("vector(1536)")? // OpenAI embedding size
  startLine Int?
  endLine   Int?
  createdAt DateTime                     @default(now())

  fileId String
  file   RepositoryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("code_embeddings")
}
