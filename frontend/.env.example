# ─────────────────────────────────────────────────────────────────────────────
# RepoLens Frontend – Environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# Next.js loads: .env.local (local overrides), .env (defaults).
# Only NEXT_PUBLIC_* are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (must match backend BASE_PATH + version, e.g. /api/v1)
# Use full origin when frontend and backend run on different hosts/ports.
NEXT_PUBLIC_API_URL=https://api.repolens.live/api/v1

# GitHub App install flow (Module 4). Redirect users here to install the app; append ?state=<workspaceId> when connecting.
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/repolens-dev/installations/new
